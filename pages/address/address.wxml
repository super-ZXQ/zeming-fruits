<view class="container">
  <view class="header">
    <text class="title">收货地址</text>
    <view class="add-btn" bindtap="addAddress">
      <text class="add-icon">+</text>
      <text>新增地址</text>
    </view>
  </view>

  <scroll-view scroll-y class="address-list">
    <view class="address-card {{item.isDefault ? 'default' : ''}}" wx:for="{{addresses}}" wx:key="id">
      <view class="card-top" bindtap="selectAddress" data-id="{{item.id}}">
        <view class="user-info">
          <text class="name">{{item.name}}</text>
          <text class="phone">{{item.phone}}</text>
          <text class="tag" wx:if="{{item.isDefault}}">默认</text>
        </view>
        <view class="address-detail">
          {{item.province}}{{item.city}}{{item.district}}{{item.detail}}
        </view>
      </view>
      
      <view class="card-bottom">
        <view class="set-default" bindtap="setDefault" data-id="{{item.id}}" wx:if="{{!item.isDefault}}">
          <icon type="{{item.isSelected ? 'success' : 'circle'}}" size="18"/>
          <text>设为默认</text>
        </view>
        <view class="default-text" wx:else>
          <icon type="success" size="18" color="#43A047"/>
          <text>默认地址</text>
        </view>
        
        <view class="actions">
          <view class="action-btn edit" bindtap="editAddress" data-id="{{item.id}}">
            <text>编辑</text>
          </view>
          <view class="action-btn delete" bindtap="deleteAddress" data-id="{{item.id}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{addresses.length === 0}}">
      <text class="empty-icon">📍</text>
      <text>暂无收货地址</text>
      <text class="empty-tip">点击上方"新增地址"添加</text>
    </view>
  </scroll-view>

  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{isEdit ? '编辑地址' : '新增地址'}}</text>
        <text class="modal-close" bindtap="closeModal">×</text>
      </view>
      
      <view class="form">
        <view class="form-item">
          <text class="label">收货人</text>
          <input class="input" placeholder="请输入收货人姓名" value="{{formData.name}}" bindinput="inputName"/>
        </view>
        
        <view class="form-item">
          <text class="label">手机号</text>
          <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{formData.phone}}" bindinput="inputPhone"/>
        </view>
        
        <view class="form-item">
          <text class="label">省份</text>
          <picker mode="region" bindchange="bindRegionChange" value="{{region}}">
            <view class="picker">
              {{region[0] && region[1] && region[2] ? region[0] + ' ' + region[1] + ' ' + region[2] : '请选择省/市/区'}}
            </view>
          </picker>
        </view>
        
        <view class="form-item">
          <text class="label">定位</text>
          <view class="location-btn" bindtap="getLocation">
            <text>📍 点击定位自动填写地址</text>
          </view>
        </view>
        
        <view class="form-item">
          <text class="label">详细地址</text>
          <textarea class="textarea" placeholder="请输入详细地址" value="{{formData.detail}}" bindinput="inputDetail"></textarea>
        </view>
        
        <view class="form-item">
          <text class="label">设为默认</text>
          <switch checked="{{formData.isDefault}}" bindchange="bindDefaultChange" color="#43A047"/>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-save" bindtap="saveAddress">保存</button>
      </view>
    </view>
  </view>
</view>