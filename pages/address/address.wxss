.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  display: flex;
  align-items: center;
  color: #43A047;
  font-size: 28rpx;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.address-list {
  height: calc(100vh - 120rpx);
}

.address-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.address-card.default {
  border: 2rpx solid #43A047;
}

.card-top {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.phone {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.tag {
  background: #43A047;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.address-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
}

.set-default, .default-text {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.default-text {
  color: #43A047;
}

.set-default icon, .default-text icon {
  margin-right: 8rpx;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
}

.action-btn.delete {
  color: #ff4d4f;
  border-color: #ff4d4f;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty text {
  font-size: 28rpx;
  color: #999;
}

.empty-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
}
