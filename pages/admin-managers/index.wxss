.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 40rpx 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.section {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
}

.arrow {
  font-size: 32rpx;
  color: #999;
}

.btn-add {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border-radius: 8rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
}

.admin-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.admin-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.admin-info {
  flex: 1;
}

.admin-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.admin-role {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.admin-role.super_admin {
  background: #fff7e6;
  color: #fa8c16;
}

.admin-role.staff {
  background: #e6f7ff;
  color: #1890ff;
}

.admin-actions {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.admin-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.admin-status.active {
  background: #f6ffed;
  color: #52c41a;
}

.admin-status.disabled {
  background: #fff1f0;
  color: #ff4d4f;
}

.btn-toggle {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 4rpx;
  border: none;
}

.btn-delete {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: #ff4d4f;
  color: white;
  border-radius: 4rpx;
  border: none;
}

.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.tips {
  background: #fffbe6;
  border-radius: 12rpx;
  padding: 20rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: #fa8c16;
  margin-bottom: 10rpx;
}

.tips-content {
  display: block;
  font-size: 24rpx;
  color: #d48806;
  margin-bottom: 8rpx;
}

.search-bar {
  display: flex;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.btn-search {
  width: 160rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.user-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.user-id {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.btn-add-user {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  background: #52c41a;
  color: white;
  border-radius: 6rpx;
  border: none;
}

.selected-name {
  display: block;
  font-size: 26rpx;
  color: #52c41a;
  margin-top: 10rpx;
}