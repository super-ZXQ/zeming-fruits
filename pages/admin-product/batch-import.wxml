<view class="container">
  <view class="header">
    <text class="title">批量导入商品</text>
  </view>

  <view class="section">
    <view class="section-title">Excel模板说明</view>
    <view class="template-info">
      <text class="info-text">请按以下格式准备Excel文件：</text>
      <view class="fields-list">
        <text class="field-item">• 名称（必填）</text>
        <text class="field-item">• 价格（必填）</text>
        <text class="field-item">• 原价（选填）</text>
        <text class="field-item">• 单位（选填，默认"份"）</text>
        <text class="field-item">• 分类（选填）</text>
        <text class="field-item">• 标签（选填）</text>
        <text class="field-item">• 图片URL（选填）</text>
      </view>
      <button class="btn-download" bindtap="downloadTemplate">下载模板</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">上传Excel文件</view>
    <view class="upload-area" bindtap="chooseExcel">
      <view class="upload-icon" wx:if="{{!excelFile}}">📁</view>
      <view class="upload-text" wx:if="{{!excelFile}}">点击选择Excel文件</view>
      <view class="file-info" wx:if="{{excelFile}}">
        <text class="file-name">{{excelName}}</text>
        <text class="file-size">{{excelSize}}</text>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{previewData.length > 0}}">
    <view class="section-title">数据预览（共{{previewData.length}}条）</view>
    <scroll-view scroll-x class="preview-table">
      <view class="table-header">
        <text class="th">名称</text>
        <text class="th">价格</text>
        <text class="th">原价</text>
        <text class="th">单位</text>
        <text class="th">分类</text>
      </view>
      <view class="table-row" wx:for="{{previewData}}" wx:key="index">
        <text class="td">{{item.name}}</text>
        <text class="td">{{item.price}}</text>
        <text class="td">{{item.originalPrice || '-'}}</text>
        <text class="td">{{item.unit || '份'}}</text>
        <text class="td">{{item.category || '-'}}</text>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="section-title">快速上新（单个商品）</view>
    <view class="quick-add">
      <view class="form-item">
        <text class="label">商品图片</text>
        <view class="image-upload" bindtap="chooseImage">
          <image wx:if="{{newProduct.imageUrl}}" src="{{newProduct.imageUrl}}" class="preview-img" mode="aspectFill"></image>
          <view wx:else class="upload-placeholder">
            <text class="plus-icon">+</text>
            <text class="upload-tip">拍照/选择图片</text>
          </view>
        </view>
      </view>
      
      <view class="form-item">
        <text class="label">商品名称</text>
        <input class="input" placeholder="请输入商品名称" value="{{newProduct.name}}" bindinput="onInputName" />
      </view>
      
      <view class="form-row">
        <view class="form-item half">
          <text class="label">现价</text>
          <input class="input" type="digit" placeholder="0.00" value="{{newProduct.price}}" bindinput="onInputPrice" />
        </view>
        <view class="form-item half">
          <text class="label">原价</text>
          <input class="input" type="digit" placeholder="0.00" value="{{newProduct.originalPrice}}" bindinput="onInputOriginalPrice" />
        </view>
      </view>
      
      <view class="form-row">
        <view class="form-item half">
          <text class="label">单位</text>
          <picker mode="selector" range="{{units}}" value="{{unitIndex}}" bindchange="onUnitChange">
            <view class="picker">{{units[unitIndex]}}</view>
          </picker>
        </view>
        <view class="form-item half">
          <text class="label">分类</text>
          <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategoryChange">
            <view class="picker">{{categories[categoryIndex].name}}</view>
          </picker>
        </view>
      </view>
      
      <view class="form-item">
        <text class="label">促销标签</text>
        <input class="input" placeholder="如：热销、新品、特价" value="{{newProduct.tag}}" bindinput="onInputTag" />
      </view>
      
      <button class="btn-add" bindtap="quickAddProduct" loading="{{adding}}">一键发布</button>
    </view>
  </view>

  <view class="footer-btns" wx:if="{{previewData.length > 0}}">
    <button class="btn-cancel" bindtap="cancelImport">取消</button>
    <button class="btn-confirm" bindtap="confirmImport" loading="{{importing}}">确认导入</button>
  </view>

  <view class="import-result" wx:if="{{importResult}}">
    <view class="result-title">导入结果</view>
    <view class="result-content">
      <text class="success-count">成功：{{importResult.success}}条</text>
      <text class="fail-count" wx:if="{{importResult.fail > 0}}">失败：{{importResult.fail}}条</text>
    </view>
  </view>
</view>