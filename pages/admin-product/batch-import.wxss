.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  padding: 40rpx 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.section {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.template-info {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
}

.fields-list {
  padding: 15rpx 0;
}

.field-item {
  font-size: 24rpx;
  color: #888;
  line-height: 2;
  display: block;
}

.btn-download {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-top: 20rpx;
}

.upload-area {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #999;
}

.file-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.file-size {
  font-size: 24rpx;
  color: #999;
}

.preview-table {
  width: 100%;
  white-space: nowrap;
}

.table-header {
  display: flex;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx 8rpx 0 0;
}

.table-row {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.th {
  flex: 1;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  min-width: 120rpx;
}

.td {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  min-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.quick-add {
  padding: 20rpx 0;
}

.form-item {
  margin-bottom: 25rpx;
}

.form-item.half {
  width: 48%;
}

.form-row {
  display: flex;
  justify-content: space-between;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.image-upload {
  width: 200rpx;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.plus-icon {
  font-size: 60rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.upload-tip {
  font-size: 24rpx;
  color: #999;
}

.btn-add {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  color: white;
  border-radius: 8rpx;
  font-size: 30rpx;
  margin-top: 30rpx;
}

.footer-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: white;
  display: flex;
  padding: 10rpx 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.import-result {
  background: #f6ffed;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #52c41a;
  margin-bottom: 15rpx;
}

.result-content {
  display: flex;
  gap: 30rpx;
}

.success-count {
  font-size: 26rpx;
  color: #52c41a;
}

.fail-count {
  font-size: 26rpx;
  color: #ff4d4f;
}