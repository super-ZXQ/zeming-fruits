<view class="container">
  <view class="header">
    <text class="header-title">店铺设置</text>
    <text class="header-tip">配置首页展示信息</text>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">📢 首页公告设置</text>
    </view>
    
    <view class="form-item">
      <text class="form-label">公告 1</text>
      <input 
        class="form-input" 
        placeholder="请输入第一条公告内容" 
        value="{{notices[0]}}" 
        bindinput="onInputNotice1" 
      />
    </view>
    
    <view class="form-item">
      <text class="form-label">公告 2</text>
      <input 
        class="form-input" 
        placeholder="请输入第二条公告内容" 
        value="{{notices[1]}}" 
        bindinput="onInputNotice2" 
      />
    </view>
    
    <view class="form-item">
      <text class="form-label">公告 3</text>
      <input 
        class="form-input" 
        placeholder="请输入第三条公告内容" 
        value="{{notices[2]}}" 
        bindinput="onInputNotice3" 
      />
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">🚚 配送设置</text>
    </view>
    
    <view class="form-item">
      <text class="form-label">免配送费门槛（元）</text>
      <input 
        class="form-input" 
        type="number" 
        placeholder="请输入免配送费金额" 
        value="{{freeDeliveryThreshold}}" 
        bindinput="onInputFreeDelivery" 
      />
    </view>
    
    <view class="form-item">
      <text class="form-label">配送费提示文字</text>
      <input 
        class="form-input" 
        placeholder="请输入配送费提示" 
        value="{{deliveryTip}}" 
        bindinput="onInputDeliveryTip" 
      />
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">📍 店铺信息</text>
    </view>
    
    <view class="form-item">
      <text class="form-label">店铺名称</text>
      <input 
        class="form-input" 
        placeholder="请输入店铺名称" 
        value="{{shopName}}" 
        bindinput="onInputShopName" 
      />
    </view>
    
    <view class="form-item">
      <text class="form-label">店铺地址</text>
      <textarea 
        class="form-textarea" 
        placeholder="请输入店铺详细地址" 
        value="{{shopAddress}}" 
        bindinput="onInputShopAddress" 
      />
    </view>
    
    <view class="form-item">
      <text class="form-label">联系电话</text>
      <input 
        class="form-input" 
        type="number" 
        placeholder="请输入联系电话" 
        value="{{shopPhone}}" 
        bindinput="onInputShopPhone" 
      />
    </view>
    
    <view class="form-item">
      <text class="form-label">营业时间</text>
      <input 
        class="form-input" 
        placeholder="请输入营业时间" 
        value="{{businessHours}}" 
        bindinput="onInputBusinessHours" 
      />
    </view>
  </view>

  <view class="save-btn" bindtap="saveSettings">
    <text>保存设置</text>
  </view>
</view>
