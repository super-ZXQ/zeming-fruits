.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.admin-nav {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  background: white;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 20rpx;
  margin: 5rpx;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #666;
}

.header {
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.header-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.product-list {
  padding: 24rpx;
}

.product-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.product-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5f9f5 0%, #e8f5e9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.product-img {
  width: 100%;
  height: 100%;
}

.product-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f9f5 0%, #e8f5e9 100%);
}

.placeholder-text {
  font-size: 50rpx;
}

.product-info {
  flex: 1;
  margin-left: 24rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
}

.product-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e53935;
}

.product-unit {
  font-size: 24rpx;
  color: #666;
  margin-left: 4rpx;
}

.product-original {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.edit-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-icon text {
  font-size: 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #bbb;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(67, 160, 71, 0.4);
  z-index: 10;
}

.add-btn text {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  background-color: #fff;
  border-radius: 24rpx;
  z-index: 101;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close text {
  font-size: 32rpx;
  color: #999;
}

.modal-body {
  padding: 32rpx;
  overflow-y: auto;
  max-height: 60vh;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item.half {
  flex: 1;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.image-upload {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f5f9f5 0%, #e8f5e9 100%);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.upload-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.upload-tip {
  position: absolute;
  bottom: 8rpx;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.upload-tip text {
  font-size: 20rpx;
  color: #fff;
}

.unit-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.unit-option {
  padding: 16rpx 32rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.unit-option.active {
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  color: #fff;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.btn-delete {
  flex: 1;
  height: 80rpx;
  background-color: #ffebee;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-delete text {
  font-size: 28rpx;
  color: #e53935;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cancel text {
  font-size: 28rpx;
  color: #666;
}

.btn-save {
  flex: 1.5;
  height: 80rpx;
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-save text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.seckill-settings {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.seckill-toggle {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toggle-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toggle-checkbox.checked {
  background-color: #e53935;
  border-color: #e53935;
}

.toggle-checkbox text {
  color: #fff;
  font-size: 24rpx;
}

.seckill-fields {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.seckill-field {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.field-label {
  font-size: 26rpx;
  color: #666;
  width: 100rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  height: 60rpx;
  background-color: #fff;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}