<view class="container">
  <view class="header">
    <text class="title">购物车</text>
    <text class="count" wx:if="{{cart.length > 0}}">共{{cart.length}}件</text>
  </view>

  <view class="content" wx:if="{{cart.length > 0}}">
    <scroll-view scroll-y class="cart-list">
      <view class="cart-item" wx:for="{{cart}}" wx:key="id">
        <view class="checkbox {{item.selected ? 'checked' : ''}}" bindtap="toggleSelect" data-id="{{item.id}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
        
        <view class="item-img">
          <image wx:if="{{item.imageUrl}}" class="product-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
          <text wx:else class="fruit-icon">{{item.emoji || '🍎'}}</text>
        </view>
        
        <view class="item-info">
          <text class="name">{{item.name}}</text>
          <view class="bottom">
            <text class="price">¥{{item.price}}</text>
            <view class="quantity">
              <text class="btn" bindtap="decreaseCount" data-id="{{item.id}}">-</text>
              <text class="num">{{item.count}}</text>
              <text class="btn" bindtap="increaseCount" data-id="{{item.id}}">+</text>
            </view>
          </view>
        </view>
        
        <view class="delete" bindtap="deleteItem" data-id="{{item.id}}">×</view>
      </view>
    </scroll-view>
  </view>

  <view class="empty" wx:else>
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车空空如也</text>
    <view class="go-btn" bindtap="goShopping">去选购</view>
  </view>

  <view class="footer" wx:if="{{cart.length > 0}}">
    <view class="select-all" bindtap="toggleSelectAll">
      <view class="checkbox {{allSelected ? 'checked' : ''}}">
        <text wx:if="{{allSelected}}">✓</text>
      </view>
      <text>全选</text>
    </view>
    
    <view class="right">
      <view class="total">
        <text>合计:</text>
        <text class="price">¥{{totalPrice}}</text>
      </view>
      <view class="checkout-btn {{selectedCount > 0 ? '' : 'disabled'}}" bindtap="goToCheckout">
        去结算({{selectedCount}})
      </view>
    </view>
  </view>
</view>