.header {
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header .title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.header .count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.content {
  height: calc(100vh - 260rpx);
  padding: 20rpx;
}

.cart-list {
  height: 100%;
}

.cart-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.checkbox.checked {
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  border-color: #43A047;
}

.checkbox text {
  font-size: 24rpx;
  color: #fff;
}

.item-img {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.fruit-icon {
  font-size: 70rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-info .name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.bottom .price {
  color: #e53935;
  font-size: 30rpx;
  font-weight: 600;
}

.bottom .price::before {
  content: '¥';
  font-size: 22rpx;
}

.quantity {
  display: flex;
  align-items: center;
  background-color: #f5f9f5;
  border-radius: 12rpx;
}

.quantity .btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.quantity .num {
  min-width: 60rpx;
  text-align: center;
  font-size: 28rpx;
}

.delete {
  font-size: 40rpx;
  color: #999;
  padding: 20rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 160rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 30rpx;
}

.go-btn {
  margin-top: 40rpx;
  padding: 22rpx 80rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all .checkbox {
  margin-right: 12rpx;
}

.select-all text {
  font-size: 26rpx;
}

.right {
  display: flex;
  align-items: center;
}

.total {
  margin-right: 32rpx;
  text-align: right;
}

.total text:first-child {
  font-size: 26rpx;
  color: #666;
}

.total .price {
  font-size: 36rpx;
  color: #e53935;
  font-weight: 600;
}

.checkout-btn {
  padding: 22rpx 52rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
}

.checkout-btn.disabled {
  background: #bdbdbd;
}