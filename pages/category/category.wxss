.container {
  display: flex;
  height: 100vh;
  background: #f3f6f1;
}

.left-menu {
  width: 172rpx;
  border-right: 1rpx solid #e5eae4;
  background: #eef2ec;
}

.menu-scroll {
  height: calc(100vh - 112rpx);
}

.menu-item {
  position: relative;
  padding: 30rpx 12rpx;
  color: #6f7973;
  font-size: 25rpx;
  text-align: center;
}

.menu-item.active {
  background: #fff;
  color: #185c3a;
  font-weight: 700;
}

.menu-item.active::before {
  position: absolute;
  top: 50%;
  left: 0;
  width: 7rpx;
  height: 38rpx;
  border-radius: 0 7rpx 7rpx 0;
  background: #185c3a;
  content: "";
  transform: translateY(-50%);
}

.right-content {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.product-scroll {
  flex: 1;
  padding: 18rpx 18rpx 132rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-card {
  position: relative;
  display: flex;
  min-height: 190rpx;
  padding: 18rpx;
  border: 1rpx solid #e8ece6;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 8rpx 22rpx rgba(35, 61, 47, 0.05);
}

.product-image {
  position: relative;
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 164rpx;
  height: 164rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: #f1f5ef;
}

.product-emoji {
  font-size: 78rpx;
}

.product-img {
  width: 100%;
  height: 100%;
}

.brand-logo {
  position: absolute;
  top: 9rpx;
  left: 9rpx;
  padding: 4rpx 10rpx;
  border-radius: 7rpx;
  background: rgba(24, 92, 58, 0.92);
  color: #fff;
  font-size: 17rpx;
}

.product-info {
  display: flex;
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
  padding-bottom: 44rpx;
  flex-direction: column;
}

.product-name {
  display: -webkit-box;
  overflow: hidden;
  color: #24362d;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.38;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.product-tag {
  align-self: flex-start;
  margin-top: 9rpx;
  padding: 4rpx 10rpx;
  border-radius: 7rpx;
  background: #fff0ed;
  color: #b9483d;
  font-size: 18rpx;
}

.product-sales {
  margin-top: 8rpx;
  color: #9aa29e;
  font-size: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 10rpx;
}

.original-price {
  color: #aab1ad;
  font-size: 20rpx;
  text-decoration: line-through;
}

.current-price {
  color: #c94236;
  font-size: 31rpx;
  font-weight: 800;
}

.discount-info {
  display: none;
}

.add-btn {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #185c3a;
  box-shadow: 0 6rpx 14rpx rgba(24, 92, 58, 0.22);
}

.add-btn text {
  color: #fff;
  font-size: 35rpx;
  font-weight: 500;
}

.add-btn:active {
  opacity: 0.78;
  transform: scale(0.94);
}

.loading-more,
.empty-products {
  padding: 80rpx 20rpx;
  color: #9aa29e;
  font-size: 24rpx;
  text-align: center;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 172rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 112rpx;
  padding: 0 20rpx;
  border-top: 1rpx solid #e7ebe5;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(35, 61, 47, 0.08);
}

.delivery-info {
  display: flex;
  align-items: center;
}

.robot-icon {
  margin-right: 9rpx;
  font-size: 34rpx;
}

.delivery-text {
  display: flex;
  flex-direction: column;
}

.delivery-text text {
  color: #3f4d45;
  font-size: 19rpx;
}

.pack-fee {
  margin-top: 3rpx;
  color: #9aa29e !important;
}

.cart-preview {
  display: flex;
  align-items: center;
  min-width: 170rpx;
  padding: 13rpx 22rpx;
  border-radius: 38rpx;
  background: #185c3a;
}

.cart-icon {
  position: relative;
  margin-right: 10rpx;
}

.cart-icon text {
  font-size: 30rpx;
}

.cart-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 5rpx;
  border: 3rpx solid #185c3a;
  border-radius: 18rpx;
  background: #d84a3d;
  color: #fff;
  font-size: 18rpx;
}

.cart-info {
  display: flex;
  align-items: center;
}

.cart-price {
  color: #fff;
  font-size: 27rpx;
  font-weight: 700;
}
