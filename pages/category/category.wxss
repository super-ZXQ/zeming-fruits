.container {
  display: flex;
  height: 100vh;
  background-color: #f5f5f5;
}

.left-menu {
  width: 180rpx;
  background-color: #fff;
  border-right: 1rpx solid #eee;
}

.menu-scroll {
  height: calc(100vh - 100rpx);
}

.menu-item {
  padding: 30rpx 16rpx;
  font-size: 26rpx;
  color: #666;
  position: relative;
  transition: all 0.2s;
  text-align: center;
}

.menu-item.active {
  background-color: #f5f9f5;
  color: #43A047;
  font-weight: 600;
}

.menu-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #66BB6A 0%, #43A047 100%);
  border-radius: 0 4rpx 4rpx 0;
}

.right-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-scroll {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f5f9f5 0%, #e8f5e9 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.product-emoji {
  font-size: 80rpx;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.brand-logo {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-tag {
  display: inline-block;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-top: 10rpx;
  align-self: flex-start;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
  gap: 12rpx;
}

.original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
}

.current-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e53935;
}

.current-price::before {
  content: '¥';
  font-size: 22rpx;
}

.discount-info {
  font-size: 22rpx;
  color: #ff9800;
  margin-top: 6rpx;
  background: #fff8e1;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

.add-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #FFD54F 0%, #FFC107 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.4);
}

.add-btn text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.add-btn:active {
  transform: scale(0.95);
}

.loading-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 180rpx;
  right: 0;
  height: 100rpx;
  background: linear-gradient(135deg, #2d2d2d 0%, #1a1a1a 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  z-index: 100;
}

.delivery-info {
  display: flex;
  align-items: center;
}

.robot-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.delivery-text {
  display: flex;
  flex-direction: column;
}

.delivery-text text {
  font-size: 22rpx;
  color: #fff;
}

.pack-fee {
  color: #aaa !important;
}

.cart-preview {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
}

.cart-icon {
  position: relative;
  margin-right: 12rpx;
}

.cart-icon text {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #e53935;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.cart-info {
  display: flex;
  align-items: center;
}

.cart-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}