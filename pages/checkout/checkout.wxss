.header {
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  padding: 30rpx;
}

.header .title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.address-section {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.address-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.address-info {
  flex: 1;
}

.address-top {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-top .name {
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.address-top .phone {
  font-size: 26rpx;
  color: #666;
}

.address-info .detail {
  font-size: 24rpx;
  color: #999;
}

.no-address {
  flex: 1;
  font-size: 28rpx;
  color: #43A047;
}

.arrow {
  font-size: 32rpx;
  color: #999;
}

.items-section {
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.item:last-child {
  border-bottom: none;
}

.item-img {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.fruit-icon {
  font-size: 50rpx;
}

.product-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
}

.item-info {
  flex: 1;
}

.item-info .name {
  font-size: 26rpx;
  font-weight: 500;
  display: block;
}

.item-info .bottom {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

.item-info .price {
  color: #e53935;
  font-size: 26rpx;
  font-weight: 600;
}

.item-info .quantity {
  font-size: 24rpx;
  color: #999;
}

.remark-section {
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.remark-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.remark-input {
  font-size: 26rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.total {
  display: flex;
  align-items: baseline;
}

.total text:first-child {
  font-size: 26rpx;
  color: #666;
}

.total .price {
  font-size: 36rpx;
  color: #e53935;
  font-weight: 600;
  margin-left: 8rpx;
}

.pay-btn {
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
}