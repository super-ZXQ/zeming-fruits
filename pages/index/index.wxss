.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  position: sticky;
  top: 0;
  z-index: 100;
}

.location {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.location-text {
  font-size: 26rpx;
  color: #fff;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location .arrow {
  font-size: 18rpx;
  color: #fff;
  margin-left: 4rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999;
}

.header-btns {
  display: flex;
  margin-left: 16rpx;
}

.header-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
}

.header-btn text {
  font-size: 36rpx;
}

.notice-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(90deg, #fff8e1 0%, #fffde7 100%);
  padding: 16rpx 24rpx;
  margin-bottom: 8rpx;
}

.notice-bar:first-child {
  background: linear-gradient(90deg, #e8f5e9 0%, #c8e6c9 100%);
}

.notice-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.notice-swiper {
  flex: 1;
  height: 40rpx;
}

.notice-text {
  font-size: 24rpx;
  color: #ff8f00;
  line-height: 40rpx;
}

.notice-bar:first-child .notice-text {
  color: #2e7d32;
  font-weight: 500;
}

.banner-swiper {
  height: 280rpx;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  border-radius: 16rpx;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.banner-emoji {
  font-size: 120rpx;
}

.quick-entry {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 16rpx;
  background-color: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.entry-icon text {
  font-size: 48rpx;
}

.entry-name {
  font-size: 24rpx;
  color: #333;
}

.seckill-section {
  background-color: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.seckill-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.seckill-title {
  display: flex;
  align-items: center;
}

.flash-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #e53935;
}

.seckill-countdown {
  display: flex;
  align-items: center;
}

.countdown-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
}

.countdown-time {
  display: flex;
  align-items: center;
}

.time-block {
  background: linear-gradient(135deg, #e53935 0%, #c62828 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  padding: 6rpx 10rpx;
  border-radius: 6rpx;
  min-width: 40rpx;
  text-align: center;
}

.time-sep {
  color: #e53935;
  font-weight: bold;
  margin: 0 4rpx;
}

.seckill-scroll {
  white-space: nowrap;
}

.seckill-list {
  display: inline-flex;
  gap: 20rpx;
}

.seckill-card {
  width: 280rpx;
  background: linear-gradient(180deg, #fff5f5 0%, #fff 100%);
  border-radius: 12rpx;
  padding: 16rpx;
  border: 2rpx solid #ffebee;
  flex-shrink: 0;
}

.seckill-image {
  width: 100%;
  height: 160rpx;
  background: linear-gradient(135deg, #f5f9f5 0%, #e8f5e9 100%);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.seckill-emoji {
  font-size: 80rpx;
}

.seckill-img {
  width: 100%;
  height: 160rpx;
  border-radius: 8rpx;
}

.seckill-info {
  display: flex;
  flex-direction: column;
}

.seckill-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.3;
  margin-bottom: 10rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #ffcdd2;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #e53935 0%, #ff5252 100%);
  border-radius: 6rpx;
}

.progress-text {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.seckill-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.seckill-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e53935;
}

.seckill-original {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
}

.limit-tag {
  font-size: 20rpx;
  color: #ff9800;
  background-color: #fff8e1;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  align-self: flex-start;
  margin-bottom: 8rpx;
}

.seckill-btn {
  background: linear-gradient(135deg, #e53935 0%, #c62828 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  padding: 16rpx 0;
  border-radius: 8rpx;
  text-align: center;
}

.hot-section {
  background-color: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.view-more {
  display: flex;
  align-items: center;
}

.view-more text {
  font-size: 24rpx;
  color: #999;
}

.view-more .arrow {
  font-size: 28rpx;
  margin-left: 4rpx;
}

.hot-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.hot-card {
  background-color: #fafafa;
  border-radius: 12rpx;
  overflow: hidden;
}

.hot-image {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #f5f9f5 0%, #e8f5e9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.hot-emoji {
  font-size: 100rpx;
}

.hot-img {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
}

.hot-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: linear-gradient(135deg, #e53935 0%, #c62828 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.hot-info {
  padding: 16rpx;
}

.hot-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.hot-desc {
  font-size: 22rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.hot-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hot-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.hot-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #e53935;
}

.hot-original {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
}

.add-cart-btn {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FFD54F 0%, #FFC107 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.4);
}

.add-cart-btn text {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}