.container {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background: #f3f6f1;
}

.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx 22rpx;
  background: #185c3a;
}

.location {
  display: flex;
  align-items: center;
  max-width: 154rpx;
  margin-right: 16rpx;
}

.location-icon {
  margin-right: 6rpx;
  font-size: 26rpx;
}

.location-text {
  overflow: hidden;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-box {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
  height: 68rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.96);
}

.search-icon {
  margin-right: 10rpx;
  font-size: 25rpx;
  opacity: 0.72;
}

.search-placeholder {
  overflow: hidden;
  color: #87918c;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-btns {
  display: flex;
  margin-left: 10rpx;
}

.header-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  margin-left: 4rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.header-btn text {
  font-size: 28rpx;
}

.notice-bar {
  display: flex;
  align-items: center;
  min-height: 62rpx;
  padding: 10rpx 28rpx;
  background: #fff;
}

.address-bar {
  border-bottom: 1rpx solid #edf0eb;
}

.announcement-bar {
  background: #fff9e9;
}

.notice-icon {
  flex-shrink: 0;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.notice-swiper {
  flex: 1;
  height: 40rpx;
}

.notice-text {
  overflow: hidden;
  color: #6f786f;
  font-size: 22rpx;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.announcement-bar .notice-text {
  color: #9b6714;
}

.banner-swiper {
  height: 260rpx;
  margin: 24rpx;
  overflow: hidden;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(24, 92, 58, 0.16);
}

.banner-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  padding: 0 42rpx;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-title {
  margin-bottom: 12rpx;
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.banner-subtitle {
  color: rgba(255, 255, 255, 0.86);
  font-size: 23rpx;
}

.banner-emoji {
  font-size: 112rpx;
}

.quick-entry {
  display: flex;
  justify-content: space-between;
  margin: 0 24rpx 22rpx;
  padding: 24rpx 18rpx 22rpx;
  border: 1rpx solid #e9ede7;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(35, 61, 47, 0.05);
}

.entry-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  margin-bottom: 12rpx;
  border-radius: 26rpx;
}

.entry-icon text {
  font-size: 43rpx;
}

.entry-name {
  color: #415048;
  font-size: 22rpx;
  white-space: nowrap;
}

.seckill-section,
.hot-section {
  margin: 0 24rpx 22rpx;
  padding: 26rpx;
  border: 1rpx solid #e9ede7;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(35, 61, 47, 0.05);
}

.seckill-header,
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.seckill-title {
  display: flex;
  align-items: center;
}

.flash-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.title-text,
.section-title {
  color: #203129;
  font-size: 30rpx;
  font-weight: 700;
}

.seckill-countdown,
.countdown-time,
.view-more {
  display: flex;
  align-items: center;
}

.countdown-label,
.view-more text {
  margin-right: 10rpx;
  color: #87918c;
  font-size: 21rpx;
}

.time-block {
  min-width: 42rpx;
  padding: 5rpx 8rpx;
  border-radius: 8rpx;
  background: #c94236;
  color: #fff;
  font-size: 21rpx;
  font-weight: 700;
  text-align: center;
}

.time-sep {
  margin: 0 4rpx;
  color: #c94236;
}

.seckill-scroll {
  white-space: nowrap;
}

.seckill-list {
  display: inline-flex;
  gap: 18rpx;
}

.seckill-card {
  flex-shrink: 0;
  width: 272rpx;
  padding: 14rpx;
  border: 1rpx solid #f3e5e1;
  border-radius: 18rpx;
  background: #fffafa;
}

.seckill-image,
.hot-image {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #f2f6f0;
}

.seckill-image {
  width: 100%;
  height: 166rpx;
  margin-bottom: 12rpx;
  border-radius: 14rpx;
}

.seckill-img,
.hot-img {
  width: 100%;
  height: 100%;
}

.seckill-emoji {
  font-size: 78rpx;
}

.seckill-info {
  display: flex;
  flex-direction: column;
}

.seckill-name {
  display: -webkit-box;
  overflow: hidden;
  min-height: 66rpx;
  margin-bottom: 10rpx;
  color: #293a31;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: normal;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  overflow: hidden;
  border-radius: 4rpx;
  background: #f5d8d4;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  background: #d64c40;
}

.progress-text {
  margin: 7rpx 0;
  color: #9a9f9c;
  font-size: 19rpx;
}

.seckill-price-row,
.hot-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.seckill-price,
.hot-price {
  color: #c94236;
  font-size: 30rpx;
  font-weight: 700;
}

.seckill-original,
.hot-original {
  color: #a8afab;
  font-size: 20rpx;
  text-decoration: line-through;
}

.limit-tag {
  align-self: flex-start;
  margin: 7rpx 0;
  padding: 3rpx 9rpx;
  border-radius: 6rpx;
  background: #fff1dd;
  color: #a46611;
  font-size: 18rpx;
}

.seckill-btn {
  padding: 13rpx 0;
  border-radius: 12rpx;
  background: #c94236;
  color: #fff;
  font-size: 23rpx;
  font-weight: 600;
  text-align: center;
}

.hot-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.hot-card {
  overflow: hidden;
  border: 1rpx solid #edf0eb;
  border-radius: 18rpx;
  background: #fff;
}

.hot-image {
  width: 100%;
  height: 210rpx;
}

.hot-emoji {
  font-size: 96rpx;
}

.hot-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 11rpx;
  border-radius: 8rpx;
  background: #c94236;
  color: #fff;
  font-size: 18rpx;
}

.hot-info {
  padding: 16rpx;
}

.hot-name,
.hot-desc {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.hot-name {
  margin-bottom: 6rpx;
  color: #293a31;
  font-size: 25rpx;
  font-weight: 600;
  -webkit-line-clamp: 1;
}

.hot-desc {
  margin-bottom: 12rpx;
  color: #929b96;
  font-size: 20rpx;
  -webkit-line-clamp: 1;
}

.hot-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.add-cart-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #185c3a;
  box-shadow: 0 6rpx 14rpx rgba(24, 92, 58, 0.2);
}

.add-cart-btn text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
}

.entry-item:active,
.seckill-btn:active,
.add-cart-btn:active {
  opacity: 0.78;
  transform: scale(0.97);
}
