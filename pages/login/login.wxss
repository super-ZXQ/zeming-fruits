.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #66BB6A 0%, #43A047 30%, #f8fcf8 30%);
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.store-logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.app-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-top: 16rpx;
}

.login-content {
  background-color: #fff;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.1);
}

.privacy-tip {
  text-align: center;
  margin-bottom: 40rpx;
}

.privacy-tip text {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.privacy-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.phone-login-btn {
  width: 100%;
  background: linear-gradient(135deg, #ef5350 0%, #c62828 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 30rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 20rpx;
}

.phone-login-btn::after {
  border: none;
}

.skip-btn {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 30rpx;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #e0e0e0;
}

.divider text {
  padding: 0 30rpx;
  font-size: 24rpx;
  color: #999;
}

.sms-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 20rpx 0;
}

.sms-icon {
  width: 80rpx;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.sms-label {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.agreement {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #9e9e9e;
  padding: 0 40rpx;
  margin-top: 40rpx;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 6rpx;
  margin-right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background-color: #ef5350;
  border-color: #ef5350;
}

.checkbox text {
  font-size: 20rpx;
  color: #fff;
}

.link {
  color: #ef5350;
  margin: 0 4rpx;
}

.agreement-hint {
  color: #9e9e9e;
  margin-right: 8rpx;
}

.privacy-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.privacy-dialog {
  position: relative;
  width: 600rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 50rpx 40rpx 40rpx;
  z-index: 10000;
}

.privacy-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.privacy-content {
  margin-bottom: 40rpx;
}

.privacy-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 16rpx;
}

.privacy-list {
  background-color: #f5f5f5;
  padding: 24rpx;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.privacy-item {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
  display: block;
}

.privacy-policy-link {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-top: 20rpx;
}

.privacy-buttons {
  display: flex;
  gap: 20rpx;
}

.privacy-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 0;
}

.privacy-btn::after {
  border: none;
}

.privacy-btn.disagree {
  background-color: #f5f5f5;
  color: #999;
}

.privacy-btn.agree {
  background: linear-gradient(135deg, #ef5350 0%, #c62828 100%);
  color: #fff;
}