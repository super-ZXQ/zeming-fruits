<view class="container">
  <view class="header">
    <view class="user-info" bindtap="handleUserInfo">
      <view class="avatar">
        <text wx:if="{{isLoggedIn && userInfo}}">{{userInfo.nickname[0] || '我'}}</text>
        <text wx:else>👤</text>
      </view>
      <view class="user-detail" wx:if="{{isLoggedIn}}">
        <text class="nickname">{{userInfo.nickname || '用户'}}</text>
        <view class="member-badge" style="background: linear-gradient(135deg, {{memberColor}} 0%, {{memberColor}}99 100%)">
          <text>{{memberName}}</text>
        </view>
      </view>
      <view class="login-tip" wx:else>
        <text class="login-text">点击登录</text>
        <text class="sub-text">登录后享受更多服务</text>
      </view>
      <text class="arrow">›</text>
    </view>
    
    <view class="member-card" wx:if="{{isLoggedIn}}" bindtap="goToRecharge">
      <view class="member-left">
        <text class="vip-icon">💎</text>
        <view class="member-info">
          <text class="member-title">会员余额</text>
          <text class="member-balance">¥{{memberBalance}}</text>
        </view>
      </view>
      <view class="member-right">
        <text>充值</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="order-section">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <view class="view-all" bindtap="goToOrders">
        <text>查看全部</text>
        <text class="arrow">›</text>
      </view>
    </view>
    
    <view class="order-tabs">
      <view class="order-tab" bindtap="goToOrders" data-status="pending">
        <view class="tab-icon">💰</view>
        <text>待付款</text>
      </view>
      <view class="order-tab" bindtap="goToOrders" data-status="paid">
        <view class="tab-icon">📦</view>
        <text>进行中</text>
      </view>
      <view class="order-tab" bindtap="goToOrders" data-status="completed">
        <view class="tab-icon">✅</view>
        <text>已完成</text>
      </view>
      <view class="order-tab" bindtap="goToOrders" data-status="refund">
        <view class="tab-icon">🔄</view>
        <text>售后</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToAddress">
      <text class="menu-icon">📍</text>
      <text>收货地址</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToCoupons">
      <text class="menu-icon">🎫</text>
      <text>优惠券</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToRecharge">
      <text class="menu-icon">💳</text>
      <text>会员充值</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="contactService">
      <text class="menu-icon">📞</text>
      <text>联系客服</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item admin-entry" bindtap="goToAdmin" wx:if="{{isAdmin}}">
      <text class="menu-icon">⚙️</text>
      <text>商品管理</text>
      <text class="admin-badge">管理员</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="logout">退出登录</view>
  </view>
</view>