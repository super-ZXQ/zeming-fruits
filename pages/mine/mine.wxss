.container {
  min-height: 100vh;
  padding-bottom: 36rpx;
  background: #f3f6f1;
}

.header {
  padding: 42rpx 30rpx 108rpx;
  background: linear-gradient(145deg, #185c3a 0%, #277a4d 100%);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  overflow: hidden;
  border: 5rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.12);
}

.avatar text {
  color: #294036;
  font-size: 52rpx;
}

.user-detail,
.login-tip {
  flex: 1;
  margin-left: 22rpx;
}

.nickname,
.login-text {
  display: block;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.member-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 10rpx;
  padding: 7rpx 17rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 22rpx;
  color: #fff;
  font-size: 20rpx;
}

.sub-text {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 21rpx;
}

.arrow {
  color: currentColor;
  font-size: 31rpx;
  opacity: 0.48;
}

.member-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid rgba(255, 229, 166, 0.36);
  border-radius: 24rpx;
  background: linear-gradient(135deg, #253c32 0%, #142a21 100%);
  box-shadow: 0 12rpx 28rpx rgba(10, 37, 25, 0.2);
}

.member-left,
.member-right {
  display: flex;
  align-items: center;
}

.vip-icon {
  margin-right: 15rpx;
  font-size: 46rpx;
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-title {
  color: rgba(255, 240, 204, 0.72);
  font-size: 20rpx;
}

.member-balance {
  color: #ffe2a3;
  font-size: 39rpx;
  font-weight: 700;
}

.member-right {
  color: #f7dfac;
  font-size: 23rpx;
}

.order-section,
.menu-section {
  border: 1rpx solid #e8ece6;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(35, 61, 47, 0.06);
}

.order-section {
  margin: -62rpx 24rpx 18rpx;
  padding: 28rpx 26rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.section-title {
  color: #24362d;
  font-size: 29rpx;
  font-weight: 800;
}

.view-all {
  display: flex;
  align-items: center;
  color: #8b958f;
  font-size: 22rpx;
}

.order-tabs {
  display: flex;
  justify-content: space-around;
}

.order-tab {
  display: flex;
  align-items: center;
  min-width: 104rpx;
  flex-direction: column;
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 10rpx;
  border-radius: 22rpx;
  background: #f0f5ef;
  font-size: 36rpx;
}

.order-tab text {
  color: #65716b;
  font-size: 22rpx;
}

.menu-section {
  margin: 0 24rpx 18rpx;
  padding: 0 22rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 94rpx;
  padding: 0 8rpx;
  border-bottom: 1rpx solid #edf0eb;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  margin-right: 16rpx;
  border-radius: 17rpx;
  background: #f0f5ef;
  font-size: 28rpx;
}

.menu-label {
  flex: 1;
  color: #304139;
  font-size: 26rpx;
}

.admin-entry {
  margin: 0 -22rpx;
  padding: 0 30rpx;
  border-radius: 0 0 24rpx 24rpx;
  background: #fff9e9;
}

.admin-badge {
  margin-right: 10rpx;
  padding: 4rpx 10rpx;
  border-radius: 7rpx;
  background: #9a681d;
  color: #fff;
  font-size: 18rpx;
}

.logout-section {
  margin: 28rpx 24rpx;
}

.logout-btn {
  padding: 24rpx;
  border: 1rpx solid #eedfdb;
  border-radius: 22rpx;
  background: #fff;
  color: #b94c42;
  font-size: 26rpx;
  text-align: center;
}

.member-card:active,
.order-tab:active,
.menu-item:active,
.logout-btn:active {
  opacity: 0.76;
}
