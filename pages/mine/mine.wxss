.header {
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  padding: 40rpx 30rpx 100rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar text {
  font-size: 56rpx;
}

.user-detail {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.member-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #fff;
}

.login-tip {
  flex: 1;
  margin-left: 24rpx;
}

.login-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.sub-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 10rpx;
}

.arrow {
  font-size: 36rpx;
  opacity: 0.6;
}

.member-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  margin-top: 30rpx;
  padding: 28rpx;
  border-radius: 20rpx;
}

.member-left {
  display: flex;
  align-items: center;
}

.vip-icon {
  font-size: 52rpx;
  margin-right: 16rpx;
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-title {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.member-balance {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.member-right {
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 24rpx;
}

.order-section {
  background-color: #fff;
  margin: -60rpx 30rpx 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.view-all {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.order-tabs {
  display: flex;
  justify-content: space-around;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-icon {
  font-size: 52rpx;
  margin-bottom: 12rpx;
}

.order-tab text {
  font-size: 24rpx;
  color: #666;
}

.menu-section {
  background-color: #fff;
  margin: 0 30rpx 20rpx;
  border-radius: 20rpx;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 12rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.admin-entry {
  background: linear-gradient(135deg, #fff8e1 0%, #fffde7 100%);
  margin: 0 -24rpx;
  padding: 28rpx 36rpx;
  border-radius: 0 0 20rpx 20rpx;
}

.admin-badge {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-item text:first-of-type {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.logout-section {
  margin: 40rpx 30rpx;
}

.logout-btn {
  background-color: #fff;
  color: #e53935;
  text-align: center;
  padding: 26rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
}