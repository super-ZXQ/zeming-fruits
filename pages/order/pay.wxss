.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.delivery-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx;
  gap: 20rpx;
}

.tab {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  color: #fff;
}

.content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 180rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.goods-count {
  font-size: 24rpx;
  color: #999;
}

.pickup-info {
  padding: 10rpx 0;
}

.pickup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.pickup-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.pickup-distance {
  font-size: 24rpx;
  color: #43A047;
  background: #e8f5e9;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.pickup-address {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.pickup-time, .pickup-phone {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.pickup-map {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border-radius: 12rpx;
}

.map-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.map-text {
  font-size: 26rpx;
  color: #1976d2;
  font-weight: 500;
}

.address-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.address-content {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.contact-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.contact-phone {
  font-size: 26rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.address-distance {
  margin-top: 12rpx;
}

.distance-badge {
  font-size: 24rpx;
  color: #43A047;
  background: #e8f5e9;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.distance-badge.error {
  color: #ff4d4f;
  background: #fff2f0;
}

.address-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.time-options {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.time-option {
  flex: 1;
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.time-option.active {
  border-color: #43A047;
  background: #f6ffed;
}

.time-radio {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  position: relative;
}

.time-option.active .time-radio {
  border-color: #43A047;
}

.time-option.active .time-radio::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  background: #43A047;
  border-radius: 50%;
}

.time-content {
  flex: 1;
}

.time-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.time-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.schedule-picker {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.picker-row:last-child {
  border-bottom: none;
}

.picker-label {
  font-size: 28rpx;
  color: #333;
}

.picker-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 100rpx;
  height: 100rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
  overflow: hidden;
}

.goods-image .product-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.price-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.goods-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.goods-original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.goods-quantity {
  font-size: 26rpx;
  color: #999;
  margin: 0 20rpx;
}

.goods-total {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.fee-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fee-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.fee-item.discount text:last-child {
  color: #ff4d4f;
}

.fee-error {
  color: #ff4d4f;
}

.remark-input {
  width: 100%;
  min-height: 100rpx;
  font-size: 28rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.remark-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.remark-option {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.remark-option .check-box {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 6rpx;
  margin-right: 12rpx;
  position: relative;
}

.remark-option.active .check-box {
  border-color: #43A047;
  background: #43A047;
}

.remark-option.active .check-box::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 20rpx;
}

.coupon-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
}

.agreement-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.agreement-row .check-box {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 6rpx;
  margin-right: 12rpx;
  position: relative;
}

.agreement-row .check-box.checked {
  border-color: #43A047;
  background: #43A047;
}

.agreement-row .check-box.checked::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 24rpx;
}

.agreement-text {
  font-size: 26rpx;
  color: #666;
}

.agreement-link {
  font-size: 26rpx;
  color: #43A047;
}

.bottom-placeholder {
  height: 260rpx;
}

.footer {
  position: fixed;
  bottom: 80rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.footer-left {
  display: flex;
  flex-direction: column;
}

.footer-left .price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 40rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.discount-tip {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-top: 6rpx;
}

.pay-btn {
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 60rpx;
  border-radius: 44rpx;
}

.pay-btn.disabled {
  background: #ccc;
}

.agreement-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
}

.agreement-section .agreement-row {
  justify-content: center;
}

.coupon-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.coupon-modal-content {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
}

.coupon-list {
  max-height: 60vh;
  padding: 20rpx;
}

.coupon-item {
  display: flex;
  align-items: center;
  background: #fff5f5;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 2rpx solid transparent;
}

.coupon-item.selected {
  border-color: #ff4d4f;
}

.coupon-left {
  width: 180rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #ff6034 0%, #ff4d4f 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.coupon-value {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.coupon-threshold {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.coupon-right {
  flex: 1;
  padding: 24rpx;
}

.coupon-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.coupon-type {
  font-size: 24rpx;
  color: #999;
}

.no-coupon {
  text-align: center;
  padding: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.privacy-modal-pay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-modal-pay .privacy-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.privacy-modal-pay .privacy-dialog {
  position: relative;
  width: 600rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 50rpx 40rpx 40rpx;
  z-index: 10000;
}

.privacy-modal-pay .privacy-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.privacy-modal-pay .privacy-content {
  margin-bottom: 40rpx;
}

.privacy-modal-pay .privacy-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 16rpx;
}

.privacy-modal-pay .privacy-warning {
  color: #ff4d4f;
  font-weight: 500;
  margin-top: 20rpx;
}

.privacy-modal-pay .privacy-list {
  background-color: #f5f5f5;
  padding: 24rpx;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.privacy-modal-pay .privacy-item {
  font-size: 26rpx;
  color: #43A047;
  line-height: 2;
  display: block;
}

.privacy-modal-pay .privacy-buttons {
  display: flex;
  gap: 20rpx;
}

.privacy-modal-pay .privacy-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 0;
}

.privacy-modal-pay .privacy-btn::after {
  border: none;
}

.privacy-modal-pay .privacy-btn.disagree {
  background-color: #f5f5f5;
  color: #999;
}

.privacy-modal-pay .privacy-btn.agree {
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  color: #fff;
}
