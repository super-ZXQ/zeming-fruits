.container {
  padding-bottom: 140rpx;
}

.detail-header {
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 50%, #2E7D32 100%);
  padding: 40rpx 30rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 10rpx;
}

.address-card, .store-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  margin: -30rpx 30rpx 20rpx;
  padding: 26rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.1);
}

.address-card > text:first-child, .store-card > text:first-child {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.address-info, .store-info {
  flex: 1;
}

.name-phone {
  margin-bottom: 10rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 24rpx;
}

.phone {
  font-size: 26rpx;
  color: #666;
}

.address-detail, .store-address {
  font-size: 24rpx;
  color: #9e9e9e;
}

.store-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}

.logistics-card {
  background-color: #fff;
  margin: 20rpx 30rpx;
  padding: 26rpx;
  border-radius: 20rpx;
}

.logistics-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.logistics-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.logistics-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.logistics-content {
  padding-left: 20rpx;
}

.logistics-item {
  display: flex;
  align-items: flex-start;
  padding-bottom: 24rpx;
  position: relative;
}

.logistics-item:last-child {
  padding-bottom: 0;
}

.logistics-item::before {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 16rpx;
  width: 2rpx;
  height: calc(100% - 16rpx);
  background-color: #e0e0e0;
}

.logistics-item:last-child::before {
  display: none;
}

.logistics-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  margin-right: 20rpx;
  margin-top: 6rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.logistics-dot.active {
  background-color: #43A047;
  box-shadow: 0 0 0 6rpx rgba(67, 160, 71, 0.2);
}

.logistics-text {
  flex: 1;
}

.logistics-desc {
  font-size: 26rpx;
  color: #333;
  display: block;
}

.logistics-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.order-info {
  background-color: #fff;
  margin: 20rpx 30rpx;
  padding: 26rpx;
  border-radius: 20rpx;
}

.info-title, .items-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 22rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  font-size: 24rpx;
}

.label {
  color: #9e9e9e;
}

.value {
  color: #333;
}

.items-card {
  background-color: #fff;
  margin: 20rpx 30rpx;
  padding: 26rpx;
  border-radius: 20rpx;
}

.item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.item:last-child {
  border-bottom: none;
}

.item-emoji {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #f5f9f5 0%, #e8f5e9 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-emoji text {
  font-size: 60rpx;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.item-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.item-bottom .price {
  font-size: 28rpx;
  color: #ff5722;
  font-weight: 600;
}

.quantity {
  font-size: 24rpx;
  color: #9e9e9e;
}

.summary-card {
  background-color: #fff;
  margin: 20rpx 30rpx;
  padding: 26rpx;
  border-radius: 20rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  font-size: 26rpx;
}

.summary-item.total {
  border-top: 1rpx solid #eee;
  margin-top: 14rpx;
  padding-top: 22rpx;
  font-weight: 600;
}

.detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.action-btn {
  padding: 22rpx 52rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}