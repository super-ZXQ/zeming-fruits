<view class="container">
  <view class="tabs">
    <view class="tab {{currentStatus === 'all' ? 'active' : ''}}" bindtap="switchTab" data-status="all">全部</view>
    <view class="tab {{currentStatus === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-status="pending">
      <text>待付款</text>
      <view class="tab-badge" wx:if="{{pendingCount > 0}}">{{pendingCount}}</view>
    </view>
    <view class="tab {{currentStatus === 'paid' ? 'active' : ''}}" bindtap="switchTab" data-status="paid">
      <text>进行中</text>
    </view>
    <view class="tab {{currentStatus === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-status="completed">已完成</view>
  </view>

  <scroll-view scroll-y class="list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="order-header">
        <view class="header-left">
          <text class="order-id">订单号: {{item.id}}</text>
          <text class="order-time">{{item.createTime}}</text>
        </view>
        <text class="order-status {{item.status}}">{{statusText[item.status]}}</text>
      </view>
      
      <view class="order-items">
        <view class="item" wx:for="{{item.items}}" wx:for-item="goods" wx:key="id" wx:if="{{index < 3}}">
          <view class="item-emoji">
            <text>{{goods.emoji || '🍎'}}</text>
          </view>
          <view class="item-info">
            <text class="name">{{goods.name}}</text>
            <text class="price">¥{{goods.price}} x {{goods.count}}</text>
          </view>
        </view>
        <view class="more-items" wx:if="{{item.items.length > 3}}">
          <text>查看更多 {{item.items.length - 3}} 件商品</text>
        </view>
      </view>
      
      <view class="order-footer">
        <text class="total">合计: <text class="price">¥{{item.totalAmount}}</text></text>
        <view class="actions">
          <view class="action-btn" wx:if="{{item.status === 'pending'}}">去支付</view>
          <view class="action-btn" wx:if="{{item.status === 'paid'}}">查看物流</view>
          <view class="action-btn" wx:if="{{item.status === 'completed'}}">再次购买</view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{orders.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无订单</text>
      <text class="empty-tip">快去选购新鲜水果吧</text>
      <view class="go-shopping" bindtap="goShopping">去购物</view>
    </view>
  </scroll-view>
</view>