.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.tabs {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab.active {
  color: #43A047;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  border-radius: 3rpx;
}

.tab-badge {
  background-color: #e53935;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

.list {
  height: calc(100vh - 90rpx);
  padding: 20rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.order-id {
  font-size: 24rpx;
  color: #999;
}

.order-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 6rpx;
}

.order-status {
  font-size: 26rpx;
  font-weight: 600;
}

.order-status.pending {
  color: #e53935;
}

.order-status.paid {
  color: #43A047;
}

.order-status.completed {
  color: #9e9e9e;
}

.order-status.refund {
  color: #ff9800;
}

.order-items {
  padding: 20rpx 0;
}

.item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.item:last-child {
  margin-bottom: 0;
}

.item-emoji {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #f5f9f5 0%, #e8f5e9 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-emoji text {
  font-size: 50rpx;
}

.item-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.price {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.more-items {
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #43A047;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.total {
  font-size: 26rpx;
  color: #333;
}

.total .price {
  color: #ff5722;
  font-weight: 600;
  font-size: 28rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 14rpx 28rpx;
  border: 2rpx solid #43A047;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #43A047;
  background: #fff;
}

.action-btn:active {
  background: #f5f9f5;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-top: 20rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.go-shopping {
  margin-top: 40rpx;
  padding: 22rpx 80rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(67, 160, 71, 0.3);
}